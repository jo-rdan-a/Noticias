<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> | Mini-CMS</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Source+Sans+3:wght@400;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body class="auth-body">
  <div class="auth-container">
    <div class="auth-card">
      <div class="auth-logo">
        <h1>Notícias</h1>
        <p>Sistema de Gerenciamento de Notícias</p>
      </div>

      <% if (typeof messages !== 'undefined') { %>
        <% if (messages.success && messages.success.length) { %>
          <div class="alert alert-success"><%= messages.success[0] %></div>
        <% } %>
        <% if (messages.error && messages.error.length) { %>
          <div class="alert alert-error"><%= messages.error[0] %></div>
        <% } %>
      <% } %>

      <%- body %>
    </div>
  </div>
</body>
</html>
